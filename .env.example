# Browser-safe frontend configuration only. Never add SUPABASE_SERVICE_ROLE_KEY here.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Same-domain deployment:
# VITE_SCRAPER_API_URL=https://alert-cia.vercel.app
# Local scraper service:
# VITE_SCRAPER_API_URL=http://localhost:3000
VITE_SCRAPER_API_URL=https://alert-cia.vercel.app

# Scraper speed tuning. Defaults are safe for most news sites.
SCRAPER_ARTICLE_CONCURRENCY=8
SCRAPER_REQUEST_TIMEOUT_MS=12000
SCRAPER_DOMAIN_DELAY_MS=125

# Optional production override. Localhost/127.0.0.1 dev ports are allowed by code.
SCRAPER_ALLOWED_ORIGINS=https://alert-cia.vercel.app,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5176,http://127.0.0.1:5176
